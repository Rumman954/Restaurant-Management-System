# Local MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/restaurant-mern

# Production (Vercel): set MONGO_URI in Vercel Environment Variables to Atlas
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/restaurant-mern?retryWrites=true&w=majority

JWT_SECRET=replace_with_secure_secret
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123
PORT=5000

# Optional. Leave empty to allow all origins (fine for same-site Vercel /api).
CLIENT_ORIGIN=http://localhost:5173,https://restaurant-management-system-omega-liard.vercel.app

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
